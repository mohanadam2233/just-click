# .env
########################
# App & Dev toggles
########################
ENV=development
LOG_LEVEL=DEBUG
HOST=0.0.0.0
PORT=7000
DEBUG=1

########################
# Security (REQUIRED)
########################
SECRET_KEY=replace-with-long-random-secret
SECURITY_PASSWORD_SALT=replace-with-salt
ENCRYPTION_KEY=sLXKm6HulAkop3wgsZUbYqABOe8e-YcDGpDz25xwvQM=

########################
# PostgreSQL (REQUIRED)
########################
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=0546655166
DATABASE_NAME=justclick_db

########################
# Redis (REQUIRED)
########################
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

########################
# CORS
########################
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]
CORS_ALLOW_ORIGIN_REGEX=

########################
# Session / Cookies
########################

#SESSION_COOKIE_NAME=session_id
