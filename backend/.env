########################
# Session / Cookies (LOCAL DEV)
########################
SESSION_COOKIE_NAME=session_id
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_MAX_AGE=86400
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_DOMAIN=
CROSS_SITE_COOKIES=false
# --------------------------------
# Biometric / Attendance Agent
# --------------------------------

# Base URL of your ERP backend API (where Flask is accessible)
# Dev on same machine:
ERP_API_BASE_URL=http://localhost:2000
# On VPS (example):
# ERP_API_BASE_URL=https://erp.yourdomain.com

# If this agent is dedicated to a single company, set its ID.
# If empty, agent loads devices for all companies.
BIOMETRIC_AGENT_COMPANY_ID=

# How often to sync logs from devices (seconds)
# 900 = 15 min, 3600 = 1 hour
BIOMETRIC_PUNCH_PULL_FREQUENCY=900

# Optional security token – same value must be validated by your backend
# For now in dev you can leave it empty.
BIOMETRIC_AGENT_TOKEN=

# Media
MEDIA_BACKEND=local
MEDIA_MAX_MB=100
MEDIA_ALLOWED_EXTS=["png","jpg","jpeg","webp","pdf","doc","docx","ppt","pptx","key","mp4","mkv","mov","csv","xlsx","xls"]

# If using S3 / MinIO
S3_ENDPOINT_URL=http://127.0.0.1:7000
S3_REGION=us-east-1
S3_BUCKET=erp-media
S3_ACCESS_KEY=your_key
S3_SECRET_KEY=your_secret
S3_PUBLIC_BASE=

# Local
LOCAL_MEDIA_ROOT=media
LOCAL_PUBLIC_BASE=/media




# DigitalPersona 4500 integration
DP4500_MODE=EXE
DP4500_EXE_PATH=C:\dp4500\capture.exe
DP4500_EXE_TIMEOUT=15

#DP4500_MODE=MOCK
#
## MOCK | EXE | DLL
#DP4500_EXE_PATH=C:\dp4500\capture.exe
#DP4500_EXE_TIMEOUT=15

# Optional: if your EXE needs extra args
DP4500_EXE_ARGS=

# ----------------------------
# email (links + branding)
# ----------------------------
APP_NAME=CMCP University Portal
APP_BASE_URL=http://localhost:3000

# ----------------------------
# Email sending (SMTP)
# ----------------------------
MAIL_PROVIDER=smtp
MAIL_FROM_EMAIL=justclick.cmc@gmail.com
MAIL_FROM_NAME=CMCP University Portal

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=justclick.cmc@gmail.com
SMTP_PASSWORD=cwjq ljct suty txwm

# ----------------------------
# Security
# ----------------------------
EMAIL_VERIFY_TOKEN_TTL_MINUTES=30
TEMP_PASSWORD_TTL_HOURS=24

# ----------------------------
# Outbox worker
# ----------------------------
EMAIL_OUTBOX_MAX_TRIES=5
EMAIL_OUTBOX_BATCH_SIZE=50

# ----------------------------
# tenant (MVP: single company)
# ----------------------------
DEFAULT_COMPANY_ID=1
SEED_DATA=1

#FRONTEND_BASE_URL=http://localhost:3000
#BACKEND_BASE_URL=http://localhost:9000

#----------- for docker --------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=0546655166
POSTGRES_DB=justclick_db